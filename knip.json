{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/cli-framework/index.ts"
  ],
  "project": ["src/**/*.ts"],
  "ignore": [
    "src/test/**",
    "src/docs/**"
  ],
  "ignoreBinaries": [
    "claude"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "exports": "warn",
    "types": "warn"
  }
}
