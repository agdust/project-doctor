{
  "name": "project-doctor",
  "version": "0.1.0",
  "description": "Project health checks, setup and migration helpers",
  "type": "module",
  "bin": {
    "project-doctor": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "cp -r src/checks/docs/license-exists/licenses dist/checks/docs/license-exists/",
    "dev": "tsc --watch",
    "check": "node --import tsx ./src/cli.ts",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest",
    "docs": "sx src/docs/generator.ts",
    "claude": "claude --dangerously-skip-permissions"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@eslint/js": "^9.39.2",
    "@inquirer/prompts": "^8.1.0",
    "@stylistic/eslint-plugin": "^5.6.1",
    "eslint": "^9.39.2",
    "json5": "^2.2.3",
    "typescript-eslint": "^8.50.0"
  }
}
